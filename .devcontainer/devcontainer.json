{
  "name": "workspace",

  "image": "mcr.microsoft.com/devcontainers/base:bookworm",

  "mounts": [
    "source=${localEnv:HOME}/.codex,target=/home/vscode/.codex,type=bind",
    "source=${localEnv:HOME}/.kube,target=/home/vscode/.kube,type=bind,consistency=cached"
  ],

  "runArgs": [
    "--security-opt=label=disable"
  ],

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },

    "ghcr.io/devcontainers-extra/features/bun:1": {},

    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},

    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest"
    }
  },

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.bun/bin"
  },

  "postCreateCommand": "bun add -g @openai/codex",

  "customizations": {
    "vscode": {
    "extensions": [
        "golang.Go",
        "eamodio.gitlens",
        "usernamehw.errorlens",
        "mikestead.dotenv"
      ]
    }
  }
}
